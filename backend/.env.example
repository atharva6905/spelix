# backend/.env.example — copy to backend/.env and fill in real values
# Never commit backend/.env — it is gitignored.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:6543/postgres

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Redis / ARQ ---
REDIS_URL=redis://localhost:6379

# --- AI: Anthropic (Phase 1 coaching) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- AI: OpenAI (Phase 1 keyframe analysis + exercise auto-detect fallback) ---
OPENAI_API_KEY=your-openai-api-key

# --- AI: Cohere (Phase 2 RAG — embed-v4.0 + rerank-v4.0-pro) ---
# Required for document ingestion (FR-RAGK-02) and hybrid retrieval (FR-RAGK-10).
# Obtain at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key

# --- Qdrant (Phase 2 vector store) ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# --- Config ---
# Optional: override default threshold config path
# THRESHOLD_CONFIG_PATH=/app/config/thresholds_v1.json
