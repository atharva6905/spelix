{
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_input?.path||'';if(f.endsWith('.py')){const{execSync}=require('child_process');try{execSync('ruff check --fix '+JSON.stringify(f),{stdio:'pipe'})}catch(e){process.stdout.write(e.stdout?.toString()||'')}}}catch(e){}})\"",
            "statusMessage": "Running ruff check --fix..."
          },
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_input?.path||'';if(f.endsWith('.py')){const{execSync}=require('child_process');try{execSync('pyright '+JSON.stringify(f),{stdio:'pipe'})}catch(e){process.stdout.write(e.stdout?.toString()||'')}}}catch(e){}})\"",
            "statusMessage": "Running pyright..."
          },
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=j.tool_input?.file_path||j.tool_input?.path||'';if(f.endsWith('.ts')||f.endsWith('.tsx')){const{execSync}=require('child_process');try{execSync('npx tsc --noEmit',{stdio:'pipe',cwd:'frontend'})}catch(e){process.stdout.write(e.stdout?.toString()||'')}}}catch(e){}})\"",
            "statusMessage": "Running tsc --noEmit..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const c=j.tool_input?.command||'';if(c.includes('git commit')||c.includes('git push')){const{execSync}=require('child_process');try{execSync('(git diff --cached; git diff) | grep -iE \\\\\\\"(sk-|password|secret|supabase_service_role|ANTHROPIC_API_KEY)\\\\\\\"',{stdio:'pipe'});process.exit(2)}catch(e){process.exit(0)}}}catch(e){}})\"",
            "statusMessage": "Checking for secrets..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd backend && uv run ruff check . --quiet; cd ../frontend && npx tsc --noEmit --quiet 2>&1 | head -20",
            "statusMessage": "Running final checks..."
          }
        ]
      }
    ]
  }
}
