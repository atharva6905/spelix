# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-token-...

# Database (PgBouncer pooler port 6543, not direct 5432)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (Phase 1 coaching)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o keyframe analysis + exercise auto-detect fallback)
OPENAI_API_KEY=sk-...

# Cohere (Phase 2 RAG - embed-v4.0 + rerank-v4.0-pro). Obtain at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key

# Qdrant (Phase 2 vector store)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Langfuse (LLM tracing / observability)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# App
SPELIX_ENV=development
